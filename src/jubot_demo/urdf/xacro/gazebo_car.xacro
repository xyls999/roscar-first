<!-- "赛博先锋" - 智能小车美学升级版 -->
<!-- 严格遵守约束: 不改变任何原有名称、参数、物理属性或轮子位置公式。 -->
<!-- 所有美化均通过在原有link内添加纯<visual>元素实现。 -->
<robot name="my_base" xmlns:xacro="http://wiki.ros.org/xacro">

    <xacro:property name="PI" value="3.1415926"/>

    <!-- [美化] 定义一套更具冲击力的专业配色方案 -->
    <material name="matte_black">
        <color rgba="0.1 0.12 0.14 1.0" />  <!-- 主体颜色: 哑光黑 -->
    </material>
    <material name="gunmetal_grey">
        <color rgba="0.4 0.44 0.48 1.0" />  <!-- 装甲颜色: 炮铜灰 -->
    </material>
    <material name="cyber_cyan_glow">
        <color rgba="0.0 0.9 0.95 1.0" />  <!-- 点缀颜色: 赛博青辉光 -->
    </material>
    <!-- 保留您原始的black材质定义 -->
    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0" />
    </material>

    <!-- 核心物理参数 (保持您原始的定义不变) -->
 <!-- 核心物理参数 -->
<xacro:property name="base_footprint_radius" value="0.001" /> 
<xacro:property name="base_link_length" value="0.2" />
<!-- [修改] 将车身宽度从0.15米改为0.12米 -->
<xacro:property name="base_link_width" value="0.12" />
<xacro:property name="base_link_height" value="0.05" />
    <xacro:property name="earth_space" value="0.01" />
    <xacro:property name="base_link_m" value="0.5" /> 

    <xacro:property name="caster_radius" value="0.015" />
    <xacro:property name="caster_m" value="0.01" />
    
    <xacro:property name="wheel_radius" value="0.0325" />
    <xacro:property name="wheel_length" value="0.015" />
    <xacro:property name="wheel_m" value="0.05" /> 

    <!-- 惯性矩阵宏 (保持您原始的定义不变) -->
    <xacro:macro name="Box_inertial_matrix" params="m l w h"><inertial><mass value="${m}" /><inertia ixx="${m*(w*w+h*h)/12}" ixy="0" ixz="0" iyy="${m*(l*l+h*h)/12}" iyz="0" izz="${m*(l*l+w*w)/12}" /></inertial></xacro:macro>
    <xacro:macro name="cylinder_inertial_matrix" params="m r h"><inertial><mass value="${m}" /><inertia ixx="${m*(3*r*r+h*h)/12}" ixy="0" ixz="0" iyy="${m*(3*r*r+h*h)/12}" iyz="0" izz="${m*r*r/2}" /></inertial></xacro:macro>
    <xacro:macro name="sphere_inertial_matrix" params="m r"><inertial><mass value="${m}" /><inertia ixx="${2*m*r*r/5}" ixy="0" ixz="0" iyy="${2*m*r*r/5}" iyz="0" izz="${2*m*r*r/5}" /></inertial></xacro:macro>

    <link name="base_footprint">
      <!-- 保持您原始的定义不变 -->
      <visual>
        <geometry>
          <sphere radius="${base_footprint_radius}" />
        </geometry>
      </visual>
    </link>

    <!-- 主底盘 (物理核心) -->
    <link name="base_link">
      <!-- 您的原始<visual>被用作主底盘的颜色 -->
      <visual>
        <geometry>
          <box size="${base_link_length} ${base_link_width} ${base_link_height}" />
        </geometry>
        <material name="matte_black" />
      </visual>
      <!-- 2. 前脸V型辉光灯带 -->
      <visual>
        <origin xyz="${base_link_length/2 - 0.01} 0.025 0" rpy="0 0 -0.785"/>
        <geometry>
            <box size="0.03 0.005 0.015"/>
        </geometry>
        <material name="cyber_cyan_glow"/>
      </visual>
      <visual>
        <origin xyz="${base_link_length/2 - 0.01} -0.025 0" rpy="0 0 0.785"/>
        <geometry>
            <box size="0.03 0.005 0.015"/>
        </geometry>
        <material name="cyber_cyan_glow"/>
      </visual>
      <!-- 3. 尾部散热格栅 -->
       <visual>
        <origin xyz="${-base_link_length/2} 0 -0.01" rpy="0 0.5 0"/>
        <geometry>
            <box size="0.01 ${base_link_width*0.8} ${base_link_height*0.6}"/>
        </geometry>
        <material name="gunmetal_grey"/>
      </visual>

      <!-- 碰撞和物理模型 (保持您原始的定义不变) -->
      <collision>
        <geometry>
          <box size="${base_link_length} ${base_link_width} ${base_link_height}" />
        </geometry>
      </collision>
      <xacro:Box_inertial_matrix m="${base_link_m}" l="${base_link_length}" w="${base_link_width}" h="${base_link_height}" />
    </link>

    <joint name="base_link2base_footprint" type="fixed">
      <parent link="base_footprint" />
      <child link="base_link" />
      <origin xyz="0 0 ${earth_space + base_link_height / 2}" />
    </joint>
    <gazebo reference="base_link">
        <material>Gazebo/DarkGrey</material>
    </gazebo>

    <!-- 驱动轮宏 (保持您原始的定义不变) -->
    <xacro:macro name="add_drive_wheel" params="name y_pos">
      <link name="${name}_wheel">
        <!-- 您的原始轮胎视觉，颜色改为哑光黑 -->
        <visual>
          <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_length}" />
          </geometry>
          <origin xyz="0.0 0.0 0.0" rpy="${PI / 2} 0.0 0.0" />
          <material name="matte_black" />
        </visual>
        <!-- [美化] 添加一个纯视觉的辉光轮毂 -->
        <visual>
            <geometry>
                <cylinder radius="${wheel_radius*0.5}" length="${wheel_length+0.002}"/>
            </geometry>
            <origin xyz="0 0 0" rpy="${PI / 2} 0 0"/>
            <material name="cyber_cyan_glow"/>
        </visual>
        <!-- 碰撞和物理模型 (保持您原始的定义不变) -->
        <collision>
          <geometry>
            <cylinder radius="${wheel_radius}" length="${wheel_length}" />
          </geometry>
          <origin xyz="0.0 0.0 0.0" rpy="${PI / 2} 0.0 0.0" />
        </collision>
        <xacro:cylinder_inertial_matrix m="${wheel_m}" r="${wheel_radius}" h="${wheel_length}" />
      </link>

      <joint name="${name}_wheel2base_link" type="continuous">
        <parent link="base_link" />
        <child link="${name}_wheel" />
        <origin xyz="0.0 ${y_pos} ${-(earth_space + base_link_height / 2 - wheel_radius)}" />
        <axis xyz="0 1 0" />
      </joint>

      <gazebo reference="${name}_wheel">
        <material>Gazebo/Red</material>
      </gazebo>
    </xacro:macro>

    <!-- 万向轮宏 (保持您原始的定义不变) -->
    <xacro:macro name="add_caster_wheel" params="name x_pos">
      <link name="${name}_caster">
        <visual>
          <geometry>
            <sphere radius="${caster_radius}" />
          </geometry>
          <!-- [美化] 颜色改为炮铜灰以匹配车身 -->
          <material name="gunmetal_grey" />
        </visual>
        <collision>
          <geometry>
            <sphere radius="${caster_radius}" />
          </geometry>
        </collision>
        <xacro:sphere_inertial_matrix m="${caster_m}" r="${caster_radius}" />
      </link>
      <joint name="${name}_caster2base_link" type="fixed">
        <parent link="base_link" />
        <child link="${name}_caster" />
        <origin xyz="${x_pos} 0.0 ${-(earth_space + base_link_height / 2 - caster_radius)}" />
      </joint>
      <gazebo reference="${name}_caster">
        <material>Gazebo/Grey</material>
        <mu1>0.1</mu1>
        <mu2>0.1</mu2>
      </gazebo>
    </xacro:macro>

    <!-- 轮子位置 (使用您原始的公式，完全不变) -->
    <xacro:add_drive_wheel name="left" y_pos="${base_link_width/2 - wheel_length/2}" />
    <xacro:add_drive_wheel name="right" y_pos="${-(base_link_width/2 - wheel_length/2)}" />

    <xacro:add_caster_wheel name="front" x_pos="${base_link_length/2 - caster_radius}" />
    <xacro:add_caster_wheel name="rear" x_pos="${-(base_link_length/2 - caster_radius)}" />

</robot>